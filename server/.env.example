# 服务端口
PORT=3001

# JWT 密钥（请改成随机字符串，生产必填）
JWT_SECRET=chisha_secret_change_me_2026

# CORS 允许的源（多个用逗号分隔，留空则允许全部）
# 示例：CORS_ORIGIN=https://你的域名,https://www.你的域名
CORS_ORIGIN=

# 资源访问基础地址（拼接上传文件 URL 用，末尾不要加斜杠）
# 示例：BASE_URL=https://chisha.example.com
# 留空时接口返回相对路径，前端自行拼接
BASE_URL=

# 微信小程序登录（暂未启用小程序可留空）
# 公众平台 → 开发管理 → 开发设置 获取
WX_APPID=
WX_SECRET=
